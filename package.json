{
  "name": "smart-quiz-app",
  "version": "1.0.0",
  "description": "智能刷题程序 - Electron桌面应用",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build && electron-builder",
    "build:web": "tsc && vite build",
    "preview": "vite preview"
  },
  "build": {
    "appId": "com.smartquiz.app",
    "compression": "maximum",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "dist-electron/**/*"
    ],
    "mac": {
      "target": "dmg"
    },
    "win": {
      "target": "nsis",
      "icon": "build/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  },
  "devDependencies": {
    "@ant-design/icons": "^5.5.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@types/sql.js": "^1.4.9",
    "@types/uuid": "^10.0.0",
    "@vitejs/plugin-react": "^4.3.4",
    "antd": "^5.22.0",
    "dayjs": "^1.11.13",
    "docx": "^9.7.1",
    "electron": "^33.0.0",
    "electron-builder": "^25.1.0",
    "mammoth": "^1.12.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.28.0",
    "recharts": "^2.13.0",
    "sql.js": "^1.11.0",
    "typescript": "^5.6.0",
    "uuid": "^11.0.0",
    "vite": "^6.0.0",
    "vite-plugin-electron": "^0.28.0",
    "vite-plugin-electron-renderer": "^0.14.6",
    "xlsx": "^0.18.5",
    "zustand": "^5.0.0"
  }
}
